# Copie para .env.local (uso local com `vercel dev`) ou configure no painel da Vercel.
# Chave da API da Anthropic — crie em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional — modelo usado para gerar as questões (padrão: claude-opus-4-8).
# Alternativas mais baratas/rápidas: claude-sonnet-4-6, claude-haiku-4-5
# MODEL=claude-opus-4-8
